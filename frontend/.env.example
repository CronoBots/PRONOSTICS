# Configuration locale pour le développement.
# Copie ce fichier en .env.local et remplis avec tes vraies valeurs.
# Le fichier .env.local est gitignored (cf. .gitignore).
#
# En production (GitHub Pages), ces variables sont injectées via les
# secrets GitHub Actions (cf. .github/workflows/deploy-pages.yml).

# === Supabase (auth + DB) ===
# Récupère ces valeurs dans Supabase dashboard → Settings → API
# Documentation setup : backend/supabase/README.md
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# === Stripe (Phase 2 — abonnements payants) ===
# Récupère cette clé dans Stripe dashboard → Developers → API keys
# (Publishable key — commence par pk_test_ ou pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxx

# === Base path (déjà géré en GH Actions) ===
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_DATA_MODE=static
