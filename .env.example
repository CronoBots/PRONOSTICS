# =============================================================================
# Sources de données NEXBET
# Laisser vide pour utiliser le mock adapter / désactiver une source.
# =============================================================================

# ---- Tier 1 : Cotes & sharp markets (priorité absolue) ----
# The Odds API — 70+ bookmakers dont bwin. Inscription : https://the-odds-api.com/
ODDS_API_KEY=

# Polymarket — sharp prediction market (USDC). Pas de clé requise pour la lecture
# publique de gamma-api.polymarket.com (l'adapter polymarket.py marche sans clé).
# En Belgique : trading bloqué, mais l'API publique reste accessible (data only).

# Manifold Markets — prediction market gratuit (sans clé), backup sharp universel.
# L'adapter manifold.py marche sans clé sur api.manifold.markets/v0.

# Kalshi — sharp prediction market US régulé CFTC. Clé facultative (read public OK).
# Inscription : https://kalshi.com (requiert KYC pour trader, mais l'API read marche
# sans login). Si tu as une clé pour limites plus généreuses :
KALSHI_KEY=

# ---- Tier 2 : Stats sports (officielles ou semi-officielles) ----
# MLB Stats API — officielle gratuite sans clé (adapter mlb_stats.py)
# NHL API — officielle gratuite sans clé (adapter nhl_stats.py)
# NBA Stats — officielle gratuite sans clé (adapter nba_stats.py)

# balldontlie.io — NBA stats joueurs + équipes (free signup obligatoire depuis 2024).
# Inscription : https://www.balldontlie.io/
BALLDONTLIE_KEY=

# API-SPORTS — multi-sport (foot/tennis/basket/baseball/hockey), 100 req/jour free.
# Inscription : https://api-sports.io/
API_SPORTS_KEY=

# API-Football (sous-domaine d'API-SPORTS) — soccer européen, alternative à
# football-data.org. Si tu as la clé API-SPORTS, c'est cette même clé qui sert.
API_FOOTBALL_KEY=

# football-data.org — Premier League / Champions / Liga (free token).
# Inscription : https://www.football-data.org/
FOOTBALL_DATA_TOKEN=

# ---- Tier 3 : Contexte (météo, etc.) ----
# OpenWeatherMap — météo pour MLB/NFL/MLS/tennis outdoor (free 1000 req/jour).
# Inscription : https://openweathermap.org/api
OPENWEATHER_KEY=

# =============================================================================
# Backend / Frontend
# =============================================================================
DATABASE_URL=sqlite:///./data/pronostics.db
LOG_LEVEL=INFO

NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql
