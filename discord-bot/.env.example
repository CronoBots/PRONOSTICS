# ⚠️ Renommer en .env et remplir. NE JAMAIS commit le .env (déjà dans .gitignore).

# ━━━━━ OBLIGATOIRE ━━━━━

# Token du bot (SECRET) — Discord Developer Portal > Bot tab > Reset Token
# Format : MXXXXXXXXXX.YYYYYY.ZZZZZZZZZZZZZZZZZZZ (3 parties séparées par points)
# ⚠️ NE JAMAIS partager publiquement ni commit. Configurer en variable d'env sur Railway.
DISCORD_BOT_TOKEN=your_bot_token_here

# ━━━━━ OPTIONNEL ━━━━━

# Application ID (public) — Dev Portal > General Information > Application ID
# Utilisé pour générer les URLs d'invitation et liens vers le bot
DISCORD_APP_ID=1508193166635958332

# Public Key (public) — Dev Portal > General Information > Public Key
# Utilisé pour valider les signatures des HTTP interactions (futur v2 webhook mode)
DISCORD_PUBLIC_KEY=63b44e092bff944881c32565701bbe800861578adb5593cdf6981165c17f53a1

# Guild ID (optionnel) — pour sync slash commands instantané sur 1 serveur
# Sans ça, sync global ~1h de propagation Discord
# Clic droit sur ton serveur (mode dev activé) > "Copy Server ID"
DISCORD_GUILD_ID=

